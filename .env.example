# ============================================================
# 환경변수 예시 파일 — 실제 키는 .env 파일에 저장 (git 제외)
# ============================================================

# 에어코리아 대기오염 API 키
# 발급: https://www.data.go.kr → "에어코리아 대기오염정보" 검색
AIRKOREA_API_KEY=your_airkorea_api_key_here

# 기상청 날씨 API 키
# 발급: https://www.data.go.kr → "기상청_단기예보" 검색
KMA_API_KEY=your_kma_api_key_here
